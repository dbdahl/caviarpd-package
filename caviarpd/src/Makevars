CARGO = "/home/dahl/.cargo/bin/cargo"
RUST_DIR = rust
RUST_LIB = $(RUST_DIR)/librust.a
RUST_TARGET_LIB = $(RUST_DIR)/target/release/librust.a
# Note: CRAN builds use .cargo/config.toml (from vendor.tar.xz) to use only two cores.
CARGO_BUILD_CMD = $(CARGO) build --release --lib
CARGO_ENV = RUSTC="/home/dahl/.cargo/bin/rustc"

RUST_DEPS = \
  Makevars.in \
  rust/.gitignore \
  rust/Cargo.lock \
  rust/Cargo.toml \
  rust/build.rs \
  rust/epa/Cargo.lock \
  rust/epa/Cargo.toml \
  rust/epa/src/clust.rs \
  rust/epa/src/epa.rs \
  rust/epa/src/lib.rs \
  rust/epa/src/perm.rs \
  rust/rbindings/.gitignore \
  rust/rbindings/Cargo.lock \
  rust/rbindings/Cargo.toml \
  rust/rbindings/src/lib.rs \
  rust/roxido/Cargo.lock \
  rust/roxido/Cargo.toml \
  rust/roxido/src/lib.rs \
  rust/roxido_macro/Cargo.lock \
  rust/roxido_macro/Cargo.toml \
  rust/roxido_macro/src/lib.rs \
  rust/src/lib.rs

PKG_LIBS = $(RUST_LIB)

all: $(SHLIB)

$(SHLIB): $(RUST_LIB)

$(RUST_LIB): $(RUST_DEPS)
	cd $(RUST_DIR) && R_CARGO_RUN_COUNTER=1 $(CARGO_ENV) $(CARGO_BUILD_CMD)
	cd $(RUST_DIR) && R_CARGO_RUN_COUNTER=2 $(CARGO_ENV) $(CARGO_BUILD_CMD)
	cp -f $(RUST_TARGET_LIB) $(RUST_LIB)
	rm -rf $(RUST_DIR)/vendor

clean:
	rm -f $(RUST_DIR)/roxido.txt $(RUST_LIB)
	rm -rf $(RUST_DIR)/.cargo-home
